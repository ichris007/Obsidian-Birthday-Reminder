{
  "name": "obsidian-birthday-reminder",
  "version": "1.1.0",
  "description": "Birthday reminder with lunar calendar, zodiac and constellation support",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
